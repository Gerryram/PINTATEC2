# ─── PINTATEC — Variables de entorno ───────────────────────────────────────
# Renombra a .env.local para desarrollo local
# En Vercel: Project Settings → Environment Variables

# Anthropic (IA para cotizaciones)
ANTHROPIC_API_KEY=sk-ant-...

# Vercel KV (base de datos para citas)
# Se genera al crear una KV Store en el Vercel Dashboard
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Resend (emails de notificación)
# Cuenta gratis en: https://resend.com
RESEND_API_KEY=re_...

# Email del administrador
ADMIN_EMAIL=tu@email.com

# Contraseña para el panel /admin
ADMIN_SECRET=pintatec2025admin
